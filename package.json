{
  "name": "nxus-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run check:docs-version && astro build && npm run build:llms && node scripts/check-docs-version.mjs --dist",
    "check:docs-version": "node scripts/check-docs-version.mjs",
    "build:llms": "node scripts/generate-llms-txt.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "sync:docs": "node scripts/sync-local-docs.mjs --examples",
    "sync:docs:all": "node scripts/sync-local-docs.mjs --all",
    "sync:docs:codex-plugins": "node scripts/sync-local-docs.mjs --codex-plugins",
    "sync:docs:examples": "node scripts/sync-local-docs.mjs --examples",
    "sync:docs:sdk": "node scripts/sync-local-docs.mjs --sdk",
    "refresh:docs": "node scripts/refresh-local-docs.mjs",
    "refresh:docs:all": "node scripts/refresh-local-docs.mjs --all"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.38.4",
    "astro": "^6.1.9",
    "sharp": "^0.34.5",
    "starlight-versions": "^0.8.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
